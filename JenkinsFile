pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/Nuth68/MidthermDevOps.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean install -DskipTests'
            }
        }

        stage('Run') {
            steps {
                sh 'mvn spring-boot:run &'
            }
        }
    }
}